rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() { return request.auth != null; }
    function platformAdmin() {
      return signedIn()
        && exists(/databases/$(database)/documents/platform_admins/$(request.auth.uid))
        && (!('isActive' in get(/databases/$(database)/documents/platform_admins/$(request.auth.uid)).data)
          || get(/databases/$(database)/documents/platform_admins/$(request.auth.uid)).data.isActive == true);
    }
    function activeCompany(companyId) {
      return exists(/databases/$(database)/documents/companies/$(companyId))
        && get(/databases/$(database)/documents/companies/$(companyId)).data.isActive == true;
    }
    function companyProfile(companyId) {
      return get(/databases/$(database)/documents/companies/$(companyId)/users/$(request.auth.uid)).data;
    }
    function companyUser(companyId) {
      return signedIn()
        && activeCompany(companyId)
        && exists(/databases/$(database)/documents/companies/$(companyId)/users/$(request.auth.uid))
        && (!('isActive' in companyProfile(companyId)) || companyProfile(companyId).isActive == true);
    }
    function companyAdmin(companyId) {
      return companyUser(companyId) && companyProfile(companyId).role in ['ADMIN', 'MASTER_ADMIN'];
    }
    function belongsToCompany(data, companyId) {
      return !('empresa_id' in data) || data.empresa_id == companyId;
    }

    match /platform_admins/{uid} {
      allow read, create, update: if platformAdmin();
      allow delete: if platformAdmin() && request.auth.uid != uid;
    }

    match /companies/{companyId} {
      allow read: if resource.data.isActive == true || platformAdmin();
      allow create, update, delete: if platformAdmin();

      match /users/{uid} {
        allow read: if platformAdmin() || (companyUser(companyId)
          && (request.auth.uid == uid || companyAdmin(companyId)));
        allow create: if platformAdmin() || (companyAdmin(companyId)
          && belongsToCompany(request.resource.data, companyId));
        allow update: if platformAdmin() || (companyAdmin(companyId)
          && belongsToCompany(resource.data, companyId)
          && belongsToCompany(request.resource.data, companyId));
        allow delete: if platformAdmin() || (companyAdmin(companyId)
          && request.auth.uid != uid && belongsToCompany(resource.data, companyId));
      }

      match /settings/{documentId} {
        allow read: if platformAdmin() || companyUser(companyId);
        allow create, update: if platformAdmin() || (companyAdmin(companyId)
          && belongsToCompany(request.resource.data, companyId));
        allow delete: if platformAdmin() || (companyAdmin(companyId)
          && belongsToCompany(resource.data, companyId));
      }

      match /{collectionName}/{documentId} {
        allow read: if collectionName in ['products', 'sales', 'categories', 'suppliers',
          'cash_registers', 'financial_entries', 'financial_exits', 'stock_movements']
          && (platformAdmin() || companyUser(companyId));
        allow create, update: if collectionName in ['products', 'sales', 'categories', 'suppliers',
          'cash_registers', 'financial_entries', 'financial_exits', 'stock_movements']
          && (platformAdmin() || (companyUser(companyId)
            && belongsToCompany(request.resource.data, companyId)));
        allow delete: if collectionName in ['products', 'sales', 'categories', 'suppliers',
          'cash_registers', 'financial_entries', 'financial_exits', 'stock_movements']
          && (platformAdmin() || (companyUser(companyId)
            && belongsToCompany(resource.data, companyId)));
      }
    }

    match /login_aliases/{aliasId} {
      allow get: if resource.data.empresa_id is string && activeCompany(resource.data.empresa_id);
      allow list: if false;
      allow create, update: if platformAdmin() || (request.resource.data.empresa_id is string
        && companyAdmin(request.resource.data.empresa_id));
      allow delete: if platformAdmin() || (resource.data.empresa_id is string
        && companyAdmin(resource.data.empresa_id));
    }

    match /{document=**} { allow read, write: if false; }
  }
}
