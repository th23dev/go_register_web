rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() { return request.auth != null; }
    function platformAdmin() {
      return signedIn()
        && exists(/databases/$(database)/documents/platform_admins/$(request.auth.uid))
        && (!('isActive' in get(/databases/$(database)/documents/platform_admins/$(request.auth.uid)).data)
          || get(/databases/$(database)/documents/platform_admins/$(request.auth.uid)).data.isActive == true);
    }
    function profile() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    function tenantUser() {
      return signedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && profile().empresa_id is string
        && (!('isActive' in profile()) || profile().isActive == true);
    }
    function tenantId() { return profile().empresa_id; }
    function tenantAdmin() { return tenantUser() && profile().role in ['ADMIN', 'MASTER_ADMIN']; }
    function activeTenant() {
      return tenantUser()
        && exists(/databases/$(database)/documents/companies/$(tenantId()))
        && get(/databases/$(database)/documents/companies/$(tenantId())).data.isActive == true;
    }
    function owns(data) { return activeTenant() && data.empresa_id == tenantId(); }
    function createsOwned() { return activeTenant() && request.resource.data.empresa_id == tenantId(); }
    function keepsOwner() { return request.resource.data.empresa_id == resource.data.empresa_id; }

    match /platform_admins/{uid} {
      allow read, create, update: if platformAdmin();
      allow delete: if platformAdmin() && request.auth.uid != uid;
    }

    match /companies/{companyId} {
      allow read: if resource.data.isActive == true || platformAdmin();
      allow create, update, delete: if platformAdmin();
    }

    match /users/{uid} {
      allow read: if platformAdmin() || (tenantUser() && (request.auth.uid == uid || (tenantAdmin() && resource.data.empresa_id == tenantId())));
      allow create: if platformAdmin() || (tenantAdmin() && request.resource.data.empresa_id == tenantId());
      allow update: if platformAdmin() || (tenantAdmin() && resource.data.empresa_id == tenantId() && keepsOwner());
      allow delete: if platformAdmin() || (tenantAdmin() && resource.data.empresa_id == tenantId() && request.auth.uid != uid);
    }

    match /login_aliases/{aliasId} {
      allow get: if resource.data.empresa_id is string
        && exists(/databases/$(database)/documents/companies/$(resource.data.empresa_id))
        && get(/databases/$(database)/documents/companies/$(resource.data.empresa_id)).data.isActive == true;
      allow list: if false;
      allow create, update: if platformAdmin() || (tenantAdmin() && request.resource.data.empresa_id == tenantId());
      allow delete: if platformAdmin() || (tenantAdmin() && resource.data.empresa_id == tenantId());
    }

    match /settings/{documentId} {
      allow read: if platformAdmin() || owns(resource.data);
      allow create: if platformAdmin() || (tenantAdmin() && createsOwned());
      allow update, delete: if platformAdmin() || (tenantAdmin() && owns(resource.data) && keepsOwner());
    }

    match /{collectionName}/{documentId} {
      allow read: if collectionName in ['products', 'sales', 'categories', 'suppliers', 'cash_registers', 'financial_entries', 'financial_exits', 'stock_movements'] && (platformAdmin() || owns(resource.data));
      allow create: if collectionName in ['products', 'sales', 'categories', 'suppliers', 'cash_registers', 'financial_entries', 'financial_exits', 'stock_movements'] && (platformAdmin() || createsOwned());
      allow update, delete: if collectionName in ['products', 'sales', 'categories', 'suppliers', 'cash_registers', 'financial_entries', 'financial_exits', 'stock_movements'] && (platformAdmin() || (owns(resource.data) && keepsOwner()));
    }

    match /{document=**} { allow read, write: if false; }
  }
}
